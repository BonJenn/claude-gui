{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blackcrab",
  "version": "0.1.3",
  "identifier": "com.bonjenn.blackcrab",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Blackcrab",
        "width": 1100,
        "height": 780,
        "minWidth": 720,
        "minHeight": 480,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGMTIyRjAyODA0NzA2QTEKUldTaEJrZUFBaThTbjk1OVJNb1BGRy9uL3hBTHk5RURPeXY3bE5qVnVQTHhFa1U2SnJrUkFIdXEK",
      "endpoints": [
        "https://github.com/BonJenn/blackcrab/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
