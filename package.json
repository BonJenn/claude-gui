{
  "name": "blackcrab",
  "private": true,
  "version": "0.1.3",
  "description": "A local desktop GUI for Claude Code sessions.",
  "author": "Jonathan Benn",
  "license": "Apache-2.0",
  "homepage": "https://github.com/BonJenn/blackcrab#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BonJenn/blackcrab.git"
  },
  "bugs": {
    "url": "https://github.com/BonJenn/blackcrab/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "node scripts/tauri-dev.mjs",
    "dev:desktop": "node scripts/tauri-dev.mjs",
    "dev:web": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:native": "node scripts/tauri-build.mjs --local",
    "build:native:signed": "node scripts/tauri-build.mjs --signed",
    "check": "npm run typecheck && cargo check --manifest-path src-tauri/Cargo.toml --locked",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.6",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^8.0.10"
  }
}
